import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
from sklearn.preprocessing import LabelEncoder, StandardScaler
from sklearn.model_selection import train_test_split as tts
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

# Load dataset
df = pd.read_csv('data1.csv')

# EDA
print(df.head())
print(df.shape)
print(df.columns)
df.info()
print(df.describe())

# Data preprocessing
df.drop_duplicates(inplace=True)

nc = df.select_dtypes(include=np.number).columns
cc = df.select_dtypes(include='object').columns

df[nc] = df[nc].fillna(df[nc].mean())

for col in cc:
    le = LabelEncoder()
    df[col] = df[col].fillna(df[col].mode()[0])
    df[col] = le.fit_transform(df[col])

# Visualization
df.hist(figsize=(10,8))
plt.suptitle("Histogram")
plt.show()

plt.figure(figsize=(10,8))
sns.heatmap(df.corr(), annot=True, cmap='coolwarm')
plt.title("Correlation HeatMap")
plt.show()

for col in nc:
    sns.boxplot(x=df[col])
    plt.title(f"BoxPlot of {col}")
    plt.show()

# Regression
target = df.columns[-1]   # safer

x = df.drop(target, axis=1)
y = df[target]

xtr, xtt, ytr, ytt = tts(x, y, test_size=0.2, random_state=42)

sc = StandardScaler()
xtr = sc.fit_transform(xtr)
xtt = sc.transform(xtt)

model = LinearRegression()
model.fit(xtr, ytr)

yp = model.predict(xtt)

# Evaluation
print("MAE :", mean_absolute_error(ytt, yp))
print("MSE :", mean_squared_error(ytt, yp))
print("R2 :", r2_score(ytt, yp))
print("Model Score:", model.score(xtt, ytt))
